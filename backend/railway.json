{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "./start.sh",
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 600,
    "restartPolicyType": "ON_FAILURE"
  }
}
